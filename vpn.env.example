# Note: All the variables to this image are optional, except HS_SERVER_URL
# which is strongly recommended. See README for more information.
# To use, copy this file to 'vpn.env' and uncomment/set your values.

# The URL that Tailscale clients will use to reach this server.
# - Must be a publicly reachable HTTPS URL for full client functionality.
# - A reverse proxy (e.g. nginx, Caddy, Traefik) handling TLS is recommended.
# - If not set, the server's public IP is auto-detected (HTTP only, limited use).
# HS_SERVER_URL=https://hs.example.com

# Port for the Headscale coordination server (default: 8080)
# HS_LISTEN_PORT=8080

# Port for the Prometheus metrics endpoint (default: 9090)
# - Set to empty to disable the metrics listener.
# HS_METRICS_PORT=9090

# Base domain for MagicDNS hostnames (default: headscale.internal)
# - Node hostnames will be: <hostname>.<base_domain>
# - Must not equal or be a parent domain of the hostname in HS_SERVER_URL.
#   For example, if HS_SERVER_URL=https://hs.example.com, do not use
#   base_domain=example.com (parent) or base_domain=hs.example.com (same).
#   The default (headscale.internal) is safe for most setups.
# HS_BASE_DOMAIN=headscale.internal

# Name of the initial user created on first run (default: admin)
# - Use one word only, no special characters except '-' and '_'.
# HS_USERNAME=admin

# Primary DNS server pushed to clients via MagicDNS (default: 1.1.1.1)
# - Accepts IPv4 or IPv6 addresses.
# HS_DNS_SRV1=1.1.1.1

# Secondary DNS server pushed to clients via MagicDNS (default: 1.0.0.1)
# HS_DNS_SRV2=1.0.0.1

# Log level: panic, fatal, error, warn, info, debug, trace (default: info)
# HS_LOG_LEVEL=info
